---
import { footerCityLinks } from '@/content/cities';

const year = 2025;
const reviewUrl = 'https://g.page/r/Cex4AH2x_-WFEAI/review';
---

<footer class="site-footer band-forest">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <div class="brand-row">
        <img src="/logo/atlas-coin-back.png" alt="" width="211" height="211" class="footer-coin" />
        <div>
          <p class="footer-wordmark">Urban&nbsp;Safari</p>
          <p class="footer-tag">
            City-wide expeditions that leave teams closer, louder,
            and happy they were invited.
          </p>
        </div>
      </div>

      <a
        class="footer-review"
        href={reviewUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          src="/google-review-qr.svg"
          alt="Scan to review Urban Safari on Google"
          width="99"
          height="99"
          class="footer-review-qr"
        />
        <span class="footer-review-text">
          <span class="footer-review-stars" aria-hidden="true">★★★★★</span>
          <span class="footer-review-label">
            Review us on Google
          </span>
        </span>
      </a>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <div class="footer-contact">
        <p class="footer-head footer-head-lg">Get in touch</p>
        <ul>
          <li>
            <a href="tel:4054374597">
              <svg
                class="footer-icon"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
              <span>(405) 437-4597</span>
            </a>
          </li>
          <li>
            <a href="mailto:mike@urbansafari.app">
              <svg
                class="footer-icon"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m2 7 10 6 10-6" />
              </svg>
              <span>mike@urbansafari.app</span>
            </a>
          </li>
        </ul>
      </div>
      <div>
        <p class="footer-head">Safari</p>
        <ul>
          <li><a href="/#tiers">Experience tiers</a></li>
          <li><a href="/#how">How it works</a></li>
          <li><a href="/#outcomes">Outcomes</a></li>
          <li><a href="/#faq">FAQ</a></li>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/support">Support</a></li>
        </ul>
      </div>
      <div class="footer-locations">
        <p class="footer-head">Locations</p>
        <ul class="city-links">
          {footerCityLinks.map((city) => (
            <li><a href={`/cities/${city.slug}/`}>{city.name}</a></li>
          ))}
          <li><a href="/cities/">All major cities</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="wrap footer-legal">
    <span>© {year} Urban Safari Game Experiences.</span>
    <span class="footer-motto">Made by a team that still high-fives after meetings.</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--section);
    padding-block: clamp(3.5rem, 8vw, 5.5rem) 2.5rem;
    border-top: 3px solid var(--ink);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .brand-row {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.6rem;
    color: var(--paper);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .footer-tag {
    color: color-mix(in srgb, var(--paper) 80%, transparent);
    max-width: 34ch;
    font-size: 0.98rem;
  }

  .footer-review {
    display: inline-flex;
    align-items: center;
    gap: 1.35rem;
    margin-top: 1.6rem;
  }
  .footer-review-qr {
    width: 99px;
    height: 99px;
    flex-shrink: 0;
    padding: 7.5px;
    border-radius: 12px;
    background: var(--paper);
    border: var(--stamp-border);
    box-shadow: var(--stamp-shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .footer-review:hover .footer-review-qr {
    transform: translate(2px, 2px);
    box-shadow: 3px 3px 0 0 var(--ink);
  }
  .footer-review-text {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .footer-review-stars {
    color: var(--gold);
    font-size: 1.425rem;
    line-height: 1;
    letter-spacing: 0.14em;
  }
  .footer-review-label {
    font-family: var(--font-mono);
    font-size: 1.17rem;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--paper) 85%, transparent);
    transition: color 0.18s;
  }
  .footer-review:hover .footer-review-label { color: var(--gold); }
  .footer-nav {
    display: grid;
    grid-template-columns: 1fr 1fr 1.5fr;
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .footer-head {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sunset);
    margin-bottom: 0.85rem;
  }
  .footer-head-lg {
    font-size: 0.92rem;
    margin-bottom: 1rem;
  }

  .footer-nav li {
    margin-bottom: 0.5rem;
  }
  .footer-nav a {
    color: color-mix(in srgb, var(--paper) 85%, transparent);
    transition: color 0.18s;
  }
  .footer-nav a:hover { color: var(--coral-soft); }

  .footer-contact a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.02rem;
  }
  .footer-icon {
    flex-shrink: 0;
    color: var(--sunset);
  }

  .footer-locations .footer-head { margin-bottom: 1rem; }
  .city-links {
    columns: 2;
    column-gap: 2rem;
  }
  .city-links li {
    break-inside: avoid;
    margin-bottom: 0.6rem;
  }

  .footer-legal {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 2.5rem;
    margin-top: 2.5rem;
    border-top: 1px solid color-mix(in srgb, var(--paper) 20%, transparent);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--paper) 70%, transparent);
  }
  .footer-motto {
    font-style: italic;
    font-family: var(--font-display);
  }

  .footer-coin { margin-top: -20px; }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-nav { grid-template-columns: repeat(2, 1fr); }
    .footer-locations { grid-column: 1 / -1; }
    .brand-row {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-tag { margin-inline: auto; }
    .footer-coin { margin-top: -20px; }
  }
</style>
