---
import { footerCityLinks } from '@/content/cities';

const year = new Date().getFullYear();
const reviewUrl = 'https://g.page/r/Cex4AH2x_-WFEAI/review';
---

<footer class="site-footer band-forest">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <div class="brand-row">
        <img src="/logo/atlas-coin-back.png" alt="" width="211" height="211" class="footer-coin" />
        <div>
          <p class="footer-wordmark">Urban&nbsp;Safari</p>
          <p class="footer-tag">
            City-wide expeditions that leave teams closer, louder,
            and happy they were invited.
          </p>
        </div>
      </div>

      <a
        class="footer-review"
        href={reviewUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          src="/google-review-qr.svg"
          alt="Scan to review Urban Safari on Google"
          width="66"
          height="66"
          class="footer-review-qr"
        />
        <span class="footer-review-text">
          <span class="footer-review-stars" aria-hidden="true">★★★★★</span>
          <span class="footer-review-label">
            Review us on Google
            <span class="footer-review-arrow">→</span>
          </span>
        </span>
      </a>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <div>
        <p class="footer-head">Safari</p>
        <ul>
          <li><a href="/#tiers">Experience tiers</a></li>
          <li><a href="/#how">How it works</a></li>
          <li><a href="/#outcomes">Outcomes</a></li>
          <li><a href="/#faq">FAQ</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-head">Get in touch</p>
        <ul>
          <li><a href="tel:4054374597">(405) 437-4597</a></li>
          <li><a href="mailto:mike@urbansafari.app">mike@urbansafari.app</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-head">Fine print</p>
        <ul>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/support">Support</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-head">Locations</p>
        <ul class="city-links">
          {footerCityLinks.map((city) => (
            <li><a href={`/cities/${city.slug}/`}>{city.name}</a></li>
          ))}
          <li><a href="/cities/">All priority cities</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="wrap footer-legal">
    <span>© {year} Urban Safari Game Experiences.</span>
    <span class="footer-motto">Made by a team that still high-fives after meetings.</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--section);
    padding-block: clamp(3.5rem, 8vw, 5.5rem) 2.5rem;
    border-top: 3px solid var(--ink);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .brand-row {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.6rem;
    color: var(--paper);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .footer-tag {
    color: color-mix(in srgb, var(--paper) 80%, transparent);
    max-width: 34ch;
    font-size: 0.98rem;
  }

  .footer-review {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    margin-top: 1.6rem;
  }
  .footer-review-qr {
    width: 66px;
    height: 66px;
    flex-shrink: 0;
    padding: 5px;
    border-radius: 8px;
    background: var(--paper);
    border: var(--stamp-border);
    box-shadow: var(--stamp-shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .footer-review:hover .footer-review-qr {
    transform: translate(2px, 2px);
    box-shadow: 3px 3px 0 0 var(--ink);
  }
  .footer-review-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .footer-review-stars {
    color: var(--gold);
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0.14em;
  }
  .footer-review-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--paper) 85%, transparent);
    transition: color 0.18s;
  }
  .footer-review:hover .footer-review-label { color: var(--gold); }
  .footer-review-arrow {
    display: inline-block;
    transition: transform 0.18s ease;
  }
  .footer-review:hover .footer-review-arrow { transform: translateX(3px); }
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .footer-head {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sunset);
    margin-bottom: 0.85rem;
  }
  .footer-nav > div:nth-child(2) { margin-left: -10px; }

  .footer-nav li {
    margin-bottom: 0.5rem;
  }
  .footer-nav a {
    color: color-mix(in srgb, var(--paper) 85%, transparent);
    transition: color 0.18s;
  }
  .footer-nav a:hover { color: var(--coral-soft); }
  .city-links {
    columns: 2;
    column-gap: 1.25rem;
  }
  .city-links li {
    break-inside: avoid;
  }

  .footer-legal {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 2.5rem;
    margin-top: 2.5rem;
    border-top: 1px solid color-mix(in srgb, var(--paper) 20%, transparent);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--paper) 70%, transparent);
  }
  .footer-motto {
    font-style: italic;
    font-family: var(--font-display);
  }

  .footer-coin { margin-top: -20px; }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-nav { grid-template-columns: repeat(2, 1fr); }
    .footer-coin { margin-top: -20px; }
  }
</style>
