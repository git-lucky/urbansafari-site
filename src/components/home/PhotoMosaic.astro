---
import Mascot from '@/components/Mascot.astro';

const shots = [
  { src: '/assets/TeamsInAction/teamimage2.jpeg',  alt: 'Team mid-jump in the city' },
  { src: '/assets/TeamsInAction/teamimage3.jpeg',  alt: 'Team cheering after a win' },
  { src: '/assets/TeamsInAction/teamimage4.jpeg',  alt: 'Team in action during a hunt' },
  { src: '/assets/TeamsInAction/teamimage6.jpeg',  alt: 'Team exploring together' },
  { src: '/assets/TeamsInAction/teamimage8.jpeg',  alt: 'Team celebrating their win' },
  { src: '/assets/TeamsInAction/teamimage9.jpeg',  alt: 'Team on their adventure' },
  { src: '/assets/TeamsInAction/teamimage10.jpeg', alt: 'Team having fun in the city' },
  { src: '/assets/TeamsInAction/teamimage11.jpeg', alt: 'Team on the adventure' },
];
---

<section class="mosaic band-sand">
  <div class="wrap">
    <header class="mosaic-head">
      <p class="eyebrow">Real teams. Real days.</p>
      <h2>This is what Monday&#8209;morning Slack looks like.</h2>
    </header>

    <div class="mosaic-grid">
      {shots.map((shot, i) => (
        <figure class={`tile tile-${i + 1}`} style={`--r:${(i % 2 === 0 ? -1 : 1) * (1 + (i % 3))}deg;`}>
          <img src={shot.src} alt={shot.alt} loading="lazy" decoding="async" />
        </figure>
      ))}

      <div class="mosaic-geo" aria-hidden="true">
        <Mascot pose="atlas-polaroid" size="lg" tilt={-6} />
      </div>
    </div>
  </div>
</section>

<style>
  .mosaic { padding-block: clamp(4rem, 8vw, 6rem); border-block: 2px solid var(--ink); }
  .mosaic-head {
    max-width: 52ch;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .mosaic-head .eyebrow { margin-bottom: 0.85rem; display: block; }

  .mosaic-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 180px;
    gap: 1rem;
  }

  .tile {
    border: var(--stamp-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--stamp-shadow);
    background: var(--paper);
    transform: rotate(var(--r, 0));
    transition: transform 0.28s cubic-bezier(.2,.9,.3,1.3);
  }
  .tile:hover { transform: translateY(-4px) rotate(0); }
  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* asymmetric feature layout */
  .tile-1 { grid-column: span 2; grid-row: span 2; }
  .tile-4 { grid-column: span 2; }
  .tile-6 { grid-row: span 2; }

  .mosaic-geo {
    position: absolute;
    right: -1.5rem;
    bottom: -2rem;
    display: none;
  }

  @media (min-width: 1100px) {
    .mosaic-geo { display: block; }
  }

  @media (max-width: 820px) {
    .mosaic-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }
    .tile-1 { grid-column: span 2; grid-row: span 2; }
    .tile-4, .tile-6 { grid-column: auto; grid-row: auto; }
  }
</style>
