---
---

<section id="contact" class="contact band-forest">
  <div class="wrap">
    <div class="contact-copy">
      <p class="eyebrow">When's your team adventure?</p>
      <h2>Let's build a day your team will be quoting in six months.</h2>
      <p class="contact-sub">
        Email or call, whichever suits. We answer fast and we don't funnel you
        through a form-maze. A real human will reply within one business day.
      </p>

      <div class="contact-ctas">
        <a href="mailto:mike@urbansafari.app?subject=Urban%20Safari%20Inquiry&body=Hi!%20I%27d%20like%20to%20learn%20more%20about%20booking%20a%20Safari.%0A%0ATeam%20size%3A%0APreferred%20date%3A%0ACity%3A%0ATier%20we%27re%20curious%20about%3A%0AAnything%20else%3A" class="btn btn-coral">
          Send us a note
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a href="tel:4054374597" class="btn phone-btn">
          <span aria-hidden="true">📞</span>
          (405) 437-4597
        </a>
      </div>

      <p class="contact-note">
        We read every email. The founder picks up the phone more often than not.
      </p>

      <a
        class="powered-by"
        href="https://huntstack.tech"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="powered-by-label">Powered by</span>
        <span class="powered-by-mark"
          ><span class="ps-hunt">hunt</span><span class="ps-stack">stack_</span></span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    border-block: 3px solid var(--ink);
    padding-block: clamp(4rem, 8vw, 6rem);
    position: relative;
    overflow: hidden;
  }
  .contact::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 20% 30%, color-mix(in srgb, var(--coral) 30%, transparent) 0, transparent 45%),
                      radial-gradient(circle at 80% 70%, color-mix(in srgb, var(--sunset) 20%, transparent) 0, transparent 55%);
    pointer-events: none;
  }

  .contact h2 {
    font-size: clamp(2rem, 1.5rem + 3vw, 3.5rem);
    line-height: 1;
    margin-bottom: 1.25rem;
    max-width: 18ch;
  }
  .contact-sub {
    font-size: 1.1rem;
    color: color-mix(in srgb, var(--paper) 80%, transparent);
    max-width: 46ch;
    margin-bottom: 2rem;
  }
  .contact-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .contact-ctas .btn {
    font-size: 1.05rem;
    padding: 1rem 1.6rem;
  }
  .contact-note {
    font-style: italic;
    color: color-mix(in srgb, var(--paper) 70%, transparent);
    font-size: 0.95rem;
  }
  .phone-btn {
    color: #000;
  }
  .phone-btn .arrow { color: #000; }

  .powered-by {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    margin-top: 2rem;
  }
  .powered-by-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--paper) 55%, transparent);
  }
  .powered-by-mark {
    font-family: 'Open Sans', var(--font-body);
    font-weight: 800;
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: -0.005em;
    transition: transform 0.18s ease;
  }
  .ps-hunt { color: #8e8e8e; }
  .ps-stack { color: var(--paper); }
  .powered-by:hover .powered-by-mark { transform: translateY(-2px); }

  @media (max-width: 820px) {
    .contact-copy { max-width: 100%; }
  }
</style>
