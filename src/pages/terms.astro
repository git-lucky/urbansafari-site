  <style>
    .legal {
      padding-block: clamp(3.5rem, 8vw, 6rem);
      background: var(--cream);
    }
    .legal-head {
      max-width: 720px;
      margin-bottom: clamp(2.5rem, 5vw, 4rem);
      padding-bottom: 2rem;
      border-bottom: 2px solid var(--ink);
    }
    .legal-head .eyebrow { display: block; margin-bottom: 0.85rem; }
    .legal-head h1 {
      font-size: clamp(3rem, 2.5rem + 2vw, 5rem);
      margin-bottom: 0.5rem;
    }
    .legal-stamp {
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.8rem;
      color: var(--forest-soft);
    }
    .prose {
      max-width: 720px;
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--ink);
    }
    .prose h2 {
      font-size: var(--step-3);
      margin-top: 3rem;
      margin-bottom: 1rem;
    }
    .prose h3 {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--forest);
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
    }
    .prose p, .prose ul { margin-bottom: 1rem; }
    .prose ul { padding-left: 1.25rem; list-style: disc; }
    .prose ul li { margin-bottom: 0.4rem; }
    .prose a { color: var(--forest); font-weight: 700; border-bottom: 2px solid var(--gold); }

    .callout {
      background: var(--sand);
      border-left: 5px solid var(--moss);
      padding: 1.25rem 1.5rem;
      border-radius: 0 12px 12px 0;
      margin: 1.5rem 0;
    }
    .callout p:last-child { margin-bottom: 0; }
    .callout p { font-size: 0.95rem; }
  </style>
</Base>
